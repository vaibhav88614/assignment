# ============================================================
# AccredVerify — Backend Environment Variables
# ============================================================
# Copy this file to `.env` in the backend/ directory.
# All values below are development defaults — safe to use as-is
# for local testing.
# ============================================================

# ---------- Application ----------
APP_NAME="Accredited Investor Verification"
APP_VERSION="1.0.0"
DEBUG=true

# ---------- Database ----------
# SQLite (default, no setup needed):
# DATABASE_URL=sqlite+aiosqlite:///./aiv.db
#
# PostgreSQL (production on Render):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/aiv
# Note: Render provides a postgres:// URL that is auto-converted.

# ---------- JWT ----------
JWT_SECRET_KEY=change-me-in-production-use-a-random-64-char-hex
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- File Uploads ----------
# UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# ---------- Cloudinary (production file storage) ----------
# Leave empty for local filesystem storage (dev).
# Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=

# ---------- Email via Resend (preferred for production) ----------
# Leave empty for console logging (dev).
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=AccredVerify <onboarding@resend.dev>

# ---------- Legacy SMTP (fallback if Resend not set) ----------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@aiv-verify.com

# ---------- Verification ----------
LETTER_VALIDITY_DAYS=90
INFO_RESPONSE_HOURS=48
ISSUER_ORG_NAME="AIV Verification Services"
ISSUER_ORG_ADDRESS="123 Verification Lane, New York, NY 10001"

# ---------- CORS ----------
# For local dev:
# CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
# For production (set to your Vercel URL):
# CORS_ORIGINS=["https://your-app.vercel.app"]
